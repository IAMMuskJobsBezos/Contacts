<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/contacts_header_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="@dimen/activity_margin"
    android:paddingTop="@dimen/normal_margin"
    android:paddingEnd="@dimen/activity_margin"
    android:paddingBottom="@dimen/normal_margin">

    <org.fossify.commons.views.MyTextView
        android:id="@+id/header_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/contacts_header_title"
        android:textSize="@dimen/actionbar_text_size" />

    <LinearLayout
        android:id="@+id/emergency_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/emergency_pill_background"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="@dimen/bigger_margin"
        android:paddingTop="@dimen/medium_margin"
        android:paddingEnd="@dimen/bigger_margin"
        android:paddingBottom="@dimen/medium_margin">

        <ImageView
            android:id="@+id/emergency_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="@dimen/medium_margin"
            android:contentDescription="@null"
            android:src="@drawable/ic_emergency_star" />

        <org.fossify.commons.views.MyTextView
            android:id="@+id/emergency_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="911"
            android:textSize="@dimen/extra_big_text_size"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />
    </LinearLayout>
</LinearLayout>
