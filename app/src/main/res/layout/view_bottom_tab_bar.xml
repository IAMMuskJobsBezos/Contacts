<?xml version="1.0" encoding="utf-8"?>
<!-- Phone fork's bottom bar, ported here so the View Contact screen carries it directly
     (2026-07-17: replaces the earlier plan of a Phone-side clone screen - private contacts
     live in each app's own local database, so only this app can reliably resolve its own
     contacts). Tapping a tab jumps into the Phone app on that tab. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottom_tab_bar_holder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/tab_bar_keypad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="@dimen/medium_margin"
        android:paddingBottom="@dimen/medium_margin">

        <ImageView
            android:id="@+id/tab_bar_keypad_icon"
            android:layout_width="@dimen/bottom_tab_icon_size"
            android:layout_height="@dimen/bottom_tab_icon_size"
            android:contentDescription="@null"
            android:src="@drawable/ic_dialpad_vector" />

        <org.fossify.commons.views.MyTextView
            android:id="@+id/tab_bar_keypad_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/tiny_margin"
            android:text="@string/keypad_tab_label"
            android:textSize="@dimen/normal_text_size" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tab_bar_contacts"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="@dimen/medium_margin"
        android:paddingBottom="@dimen/medium_margin">

        <ImageView
            android:id="@+id/tab_bar_contacts_icon"
            android:layout_width="@dimen/bottom_tab_icon_size"
            android:layout_height="@dimen/bottom_tab_icon_size"
            android:contentDescription="@null"
            android:src="@drawable/ic_person_vector" />

        <org.fossify.commons.views.MyTextView
            android:id="@+id/tab_bar_contacts_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/tiny_margin"
            android:text="@string/contacts_tab_label"
            android:textSize="@dimen/normal_text_size" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tab_bar_recents"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="@dimen/medium_margin"
        android:paddingBottom="@dimen/medium_margin">

        <ImageView
            android:id="@+id/tab_bar_recents_icon"
            android:layout_width="@dimen/bottom_tab_icon_size"
            android:layout_height="@dimen/bottom_tab_icon_size"
            android:contentDescription="@null"
            android:src="@drawable/ic_clock_vector" />

        <org.fossify.commons.views.MyTextView
            android:id="@+id/tab_bar_recents_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/tiny_margin"
            android:text="@string/recent_tab_label"
            android:textSize="@dimen/normal_text_size" />
    </LinearLayout>
</LinearLayout>
