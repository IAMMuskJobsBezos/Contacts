<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/contact_wrapper"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <include
        android:id="@+id/contacts_header"
        layout="@layout/view_contacts_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <ScrollView
        android:id="@+id/contact_scrollview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="none"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:id="@+id/contact_holder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/activity_margin"
            android:paddingEnd="@dimen/activity_margin"
            android:paddingBottom="@dimen/section_margin">

            <ImageView
                android:id="@+id/contact_photo"
                android:layout_width="@dimen/edit_contact_avatar_size"
                android:layout_height="@dimen/edit_contact_avatar_size"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/normal_margin"
                android:contentDescription="@string/change_photo"
                android:src="@drawable/avatar_placeholder" />

            <org.fossify.commons.views.MyTextView
                android:id="@+id/contact_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/bigger_margin"
                android:gravity="center"
                android:textSize="@dimen/edit_contact_title_size"
                tools:text="@string/new_contact" />

            <LinearLayout
                android:id="@+id/contact_buttons_holder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/big_margin"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/contact_cancel_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/button_rounded_rect_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingTop="@dimen/normal_margin"
                    android:paddingBottom="@dimen/normal_margin">

                    <ImageView
                        android:id="@+id/contact_cancel_icon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="@dimen/medium_margin"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_cross_vector" />

                    <org.fossify.commons.views.MyTextView
                        android:id="@+id/contact_cancel_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/cancel"
                        android:textSize="@dimen/big_text_size" />
                </LinearLayout>

                <Space
                    android:layout_width="@dimen/big_margin"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:id="@+id/contact_save_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/button_rounded_rect_background"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingTop="@dimen/normal_margin"
                    android:paddingBottom="@dimen/normal_margin">

                    <ImageView
                        android:id="@+id/contact_save_icon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="@dimen/medium_margin"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_check_vector" />

                    <org.fossify.commons.views.MyTextView
                        android:id="@+id/contact_save_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/save"
                        android:textSize="@dimen/big_text_size" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:id="@+id/contact_buttons_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/big_margin"
                android:background="@color/divider_grey" />

            <org.fossify.commons.views.MyEditText
                android:id="@+id/contact_first_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/section_margin"
                android:hint="@string/first_name"
                android:inputType="textCapWords"
                android:maxLines="1"
                android:singleLine="true"
                android:textCursorDrawable="@null"
                android:textSize="@dimen/extra_big_text_size" />

            <org.fossify.commons.views.MyEditText
                android:id="@+id/contact_surname"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/section_margin"
                android:hint="@string/last_name"
                android:inputType="textCapWords"
                android:maxLines="1"
                android:singleLine="true"
                android:textCursorDrawable="@null"
                android:textSize="@dimen/extra_big_text_size" />

            <org.fossify.commons.views.MyEditText
                android:id="@+id/contact_number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/section_margin"
                android:hint="@string/phone_number"
                android:inputType="phone"
                android:maxLines="1"
                android:singleLine="true"
                android:textCursorDrawable="@null"
                android:textSize="@dimen/extra_big_text_size" />

            <LinearLayout
                android:id="@+id/contact_optional_toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/section_margin"
                android:background="@drawable/pill_background"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="@dimen/bigger_margin"
                android:paddingTop="@dimen/normal_margin"
                android:paddingEnd="@dimen/bigger_margin"
                android:paddingBottom="@dimen/normal_margin">

                <ImageView
                    android:id="@+id/contact_optional_arrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="@dimen/medium_margin"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_down_vector" />

                <org.fossify.commons.views.MyTextView
                    android:id="@+id/contact_optional_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/show_optional_fields"
                    android:textSize="@dimen/big_text_size" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/contact_optional_holder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <org.fossify.commons.views.MyEditText
                    android:id="@+id/contact_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/section_margin"
                    android:hint="@string/email"
                    android:inputType="textEmailAddress"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textCursorDrawable="@null"
                    android:textSize="@dimen/extra_big_text_size" />

                <org.fossify.commons.views.MyEditText
                    android:id="@+id/contact_address_line_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/section_margin"
                    android:hint="@string/address_line_1"
                    android:inputType="textPostalAddress|textCapWords"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textCursorDrawable="@null"
                    android:textSize="@dimen/extra_big_text_size" />

                <org.fossify.commons.views.MyEditText
                    android:id="@+id/contact_address_line_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/section_margin"
                    android:hint="@string/address_line_2"
                    android:inputType="textPostalAddress|textCapWords"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textCursorDrawable="@null"
                    android:textSize="@dimen/extra_big_text_size" />

                <org.fossify.commons.views.MyEditText
                    android:id="@+id/contact_city"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/section_margin"
                    android:hint="@string/city"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textCursorDrawable="@null"
                    android:textSize="@dimen/extra_big_text_size" />

                <org.fossify.commons.views.MyEditText
                    android:id="@+id/contact_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/section_margin"
                    android:hint="@string/region"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textCursorDrawable="@null"
                    android:textSize="@dimen/extra_big_text_size" />

                <org.fossify.commons.views.MyEditText
                    android:id="@+id/contact_zip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/section_margin"
                    android:hint="@string/zip_code"
                    android:inputType="number"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textCursorDrawable="@null"
                    android:textSize="@dimen/extra_big_text_size" />

                <org.fossify.commons.views.MyEditText
                    android:id="@+id/contact_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/section_margin"
                    android:hint="@string/notes"
                    android:inputType="textCapSentences|textMultiLine"
                    android:textCursorDrawable="@null"
                    android:textSize="@dimen/extra_big_text_size" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
